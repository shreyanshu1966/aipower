{%- capture section_settings -%}
{
  "stackable": false,
  "layout": "vertical"
}
{%- endcapture -%}

<section class="section tc-section reveal" data-section-id="{{ section.id }}" data-section-type="product-grid" data-section-settings="{{ section_settings | escape_once }}">
  <div class="container">
    <header class="tc-header">
      <h2 class="tc-title">{{ section.settings.title | escape }}</h2>

      <div class="tabbed-collections__nav">
        {%- for block in section.blocks -%}
          <button type="button" class="tab-btn {% if forloop.first %}is-active{% endif %}" data-target="tab-{{ section.id }}-{{ forloop.index }}">
            {{ block.settings.title | escape }}
          </button>
        {%- endfor -%}
      </div>
    </header>
  </div>

  <div class="container container--flush">
    {%- for block in section.blocks -%}
      {%- assign collection = collections[block.settings.collection] -%}
      <div id="tab-{{ section.id }}-{{ forloop.index }}" class="tab-content" style="display: {% if forloop.first %}block{% else %}none{% endif %};">
        {%- capture product_list -%}
          <div class="product-list product-list--vertical product-list--scrollable">
            {%- assign use_placeholder = true -%}
            {%- if collection == blank -%}
              {%- assign products = (1..section.settings.products_count) -%}
            {%- else -%}
              {%- assign products = collection.products -%}
              {%- assign use_placeholder = false -%}
            {%- endif -%}

            {%- for product in products limit: section.settings.products_count -%}
              {%- assign products_per_row = section.settings.products_count | at_most: 6 -%}
              {%- capture grid_classes -%}1/4--lap 1/{{ products_per_row | minus: 1 }}--desk 1/{{ products_per_row }}--wide{%- endcapture -%}

              {%- if use_placeholder -%}
                {%- render 'product-item-placeholder', product: product, grid_classes: grid_classes, show_add_to_cart: true -%}
              {%- else -%}
                {%- render 'product-item', product: product, grid_classes: grid_classes, show_add_to_cart: true -%}
              {%- endif -%}
            {%- endfor -%}
          </div>
        {%- endcapture -%}

        <div class="scroller">
          <div class="scroller__inner">
            {{ product_list }}
          </div>
        </div>
      </div>
    {%- endfor -%}
  </div>
</section>

<style>
  /* ── Tabbed Collections ───────────────────────────────── */
  .tc-section { padding-top: 80px; padding-bottom: 80px; }

  .tc-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
    flex-wrap: wrap;
    padding-bottom: 28px;
    border-bottom: 1px solid rgba(0, 0, 0, 0.08);
    margin-bottom: 36px;
  }

  .tc-title {
    font-size: 32px;
    font-weight: 900;
    letter-spacing: -0.03em;
    line-height: 1;
    text-transform: uppercase;
    margin: 0;
  }

  .tabbed-collections__nav {
    display: flex;
    align-items: center;
    gap: 0;
  }

  .tab-btn {
    background: none;
    border: none;
    border-bottom: 2px solid transparent;
    font-size: 12px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    cursor: pointer;
    padding: 8px 20px 10px;
    color: rgba(0, 0, 0, 0.4);
    white-space: nowrap;
    flex-shrink: 0;
    transition: color 0.2s ease, border-color 0.2s ease;
  }

  .tab-btn:hover { color: rgba(0, 0, 0, 0.75); }

  .tab-btn.is-active {
    color: #0d0d0d;
    border-bottom-color: #e60000;
  }

  @media screen and (max-width: 767px) {
    .tc-header { flex-direction: column; align-items: flex-start; gap: 16px; }
    .tc-title { font-size: 24px; }

    .tabbed-collections__nav {
      overflow-x: auto;
      -webkit-overflow-scrolling: touch;
      scrollbar-width: none;
      width: 100%;
    }
    .tabbed-collections__nav::-webkit-scrollbar { display: none; }
    .tab-btn { padding: 6px 14px 8px; font-size: 11px; }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    var tabs     = document.querySelectorAll('#shopify-section-{{ section.id }} .tab-btn');
    var contents = document.querySelectorAll('#shopify-section-{{ section.id }} .tab-content');

    tabs.forEach(function(tab) {
      tab.addEventListener('click', function() {
        tabs.forEach(function(t) { t.classList.remove('is-active'); });
        contents.forEach(function(c) { c.style.display = 'none'; });

        tab.classList.add('is-active');
        var target = document.getElementById(tab.getAttribute('data-target'));
        if (target) target.style.display = 'block';
      });
    });
  });
</script>

{% schema %}
{
  "name": "Tabbed collections",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "Discovery"
    },
    {
      "type": "range",
      "id": "products_count",
      "label": "Products to show per tab",
      "min": 4,
      "max": 12,
      "step": 1,
      "default": 8
    }
  ],
  "blocks": [
    {
      "type": "collection",
      "name": "Collection Tab",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Tab Title",
          "default": "Featured"
        },
        {
          "type": "collection",
          "id": "collection",
          "label": "Collection"
        }
      ]
    }
  ],
  "presets": [
    {
      "category": "Collections",
      "name": "Tabbed collections",
      "blocks": [
        {
          "type": "collection",
          "settings": {
            "title": "Featured"
          }
        },
        {
          "type": "collection",
          "settings": {
            "title": "New Arrivals"
          }
        }
      ]
    }
  ]
}
{% endschema %}
