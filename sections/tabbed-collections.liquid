{%- capture section_settings -%}
{
  "stackable": false,
  "layout": "vertical"
}
{%- endcapture -%}

<section class="tc-section section" data-section-id="{{ section.id }}" data-section-type="product-grid" data-section-settings="{{ section_settings | escape_once }}">

  <div class="container">
    <div class="tc__header">
      {%- if section.settings.title != blank -%}
        <h2 class="tc__heading heading h3">{{ section.settings.title | escape }}</h2>
      {%- endif -%}

      {%- if section.blocks.size > 1 -%}
        <div class="tc__nav" role="tablist" aria-label="{{ section.settings.title | escape }}">
          {%- for block in section.blocks -%}
            <button
              type="button"
              class="tc__tab{% if forloop.first %} tc__tab--active{% endif %}"
              role="tab"
              aria-selected="{% if forloop.first %}true{% else %}false{% endif %}"
              aria-controls="tc-panel-{{ section.id }}-{{ forloop.index }}"
              data-tc-tab="{{ section.id }}"
              data-tc-target="tc-panel-{{ section.id }}-{{ forloop.index }}"
              {{ block.shopify_attributes }}>
              {{ block.settings.title | escape }}
            </button>
          {%- endfor -%}
        </div>
      {%- endif -%}
    </div>
  </div>

  <div class="container">
    {%- for block in section.blocks -%}
      {%- assign collection = collections[block.settings.collection] -%}
      {%- assign filter_sale = false -%}
      {%- if block.settings.filter == 'on_sale' -%}
        {%- assign filter_sale = true -%}
      {%- endif -%}

      <div
        id="tc-panel-{{ section.id }}-{{ forloop.index }}"
        class="tc__panel{% if forloop.first %} tc__panel--active{% endif %}"
        role="tabpanel"
        aria-labelledby="tc-tab-{{ section.id }}-{{ forloop.index }}"
        aria-hidden="{% if forloop.first %}false{% else %}true{% endif %}"
        {% unless forloop.first %}style="display: none;"{% endunless %}>

        <div class="tc__grid">
          {%- if collection != blank -%}
            {%- if filter_sale -%}
              {%- assign shown = 0 -%}
              {%- for product in collection.products limit: 100 -%}
                {%- if shown >= section.settings.products_count -%}{%- break -%}{%- endif -%}
                {%- if product.price < product.compare_at_price -%}
                  {%- render 'product-item', product: product, grid_classes: 'tc__card', show_add_to_cart: true -%}
                  {%- assign shown = shown | plus: 1 -%}
                {%- endif -%}
              {%- endfor -%}
            {%- else -%}
              {%- for product in collection.products limit: section.settings.products_count -%}
                {%- render 'product-item', product: product, grid_classes: 'tc__card', show_add_to_cart: true -%}
              {%- endfor -%}
            {%- endif -%}
          {%- else -%}
            {%- for i in (1..section.settings.products_count) -%}
              {%- render 'product-item-placeholder', product: i, grid_classes: 'tc__card', show_add_to_cart: true -%}
            {%- endfor -%}
          {%- endif -%}
        </div>

      </div>
    {%- endfor -%}
  </div>

</section>

<style>
  #shopify-section-{{ section.id }} {
    background: {{ section.settings.background }};
    padding: 64px 0 72px;
  }

  /* ── Header ─────────────────────────────────────────── */
  #shopify-section-{{ section.id }} .tc__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 16px 32px;
    margin-bottom: 36px;
  }

  #shopify-section-{{ section.id }} .tc__heading {
    margin: 0;
    flex-shrink: 0;
  }

  /* ── Tab nav ─────────────────────────────────────────── */
  #shopify-section-{{ section.id }} .tc__nav {
    display: flex;
    border-bottom: 2px solid #e2e2e2;
  }

  #shopify-section-{{ section.id }} .tc__tab {
    position: relative;
    background: none;
    border: none;
    padding: 10px 22px 12px;
    font-size: 14px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    cursor: pointer;
    color: #888;
    transition: color 0.18s ease;
    white-space: nowrap;
  }

  #shopify-section-{{ section.id }} .tc__tab::after {
    content: '';
    position: absolute;
    bottom: -2px;
    left: 0;
    right: 0;
    height: 2px;
    background: #e60000;
    transform: scaleX(0);
    transition: transform 0.22s ease;
  }

  #shopify-section-{{ section.id }} .tc__tab:hover {
    color: #222;
  }

  #shopify-section-{{ section.id }} .tc__tab--active {
    color: #e60000;
  }

  #shopify-section-{{ section.id }} .tc__tab--active::after {
    transform: scaleX(1);
  }

  /* ── Product grid ────────────────────────────────────── */
  #shopify-section-{{ section.id }} .tc__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 18px;
    padding-top: 28px;
  }

  #shopify-section-{{ section.id }} .product-item.tc__card {
    width: auto !important;
    background: #ffffff;
    border-radius: 3px;
    box-shadow: 0 1px 4px rgba(0, 0, 0, 0.06);
    transition: box-shadow 0.24s ease, transform 0.24s ease;
    overflow: hidden;
  }

  #shopify-section-{{ section.id }} .product-item.tc__card:hover {
    box-shadow: 0 6px 20px rgba(0, 0, 0, 0.11);
    transform: translateY(-2px);
  }

  /* ── Add to Cart: reveal on hover ────────────────────── */
  #shopify-section-{{ section.id }} .product-item__action-list {
    opacity: 0;
    transform: translateY(8px);
    transition: opacity 0.2s ease, transform 0.2s ease;
    pointer-events: none;
  }

  #shopify-section-{{ section.id }} .product-item.tc__card:hover .product-item__action-list,
  #shopify-section-{{ section.id }} .product-item.tc__card:focus-within .product-item__action-list {
    opacity: 1;
    transform: translateY(0);
    pointer-events: auto;
  }

  /* Always show on touch devices */
  @media (hover: none) {
    #shopify-section-{{ section.id }} .product-item__action-list {
      opacity: 1;
      transform: none;
      pointer-events: auto;
    }
  }

  /* ── Responsive ─────────────────────────────────────── */
  @media screen and (max-width: 999px) {
    #shopify-section-{{ section.id }} .tc__grid {
      grid-template-columns: repeat(3, 1fr);
    }

    #shopify-section-{{ section.id }} .tc__header {
      flex-direction: column;
      align-items: flex-start;
    }
  }

  @media screen and (max-width: 640px) {
    #shopify-section-{{ section.id }} {
      padding: 44px 0 52px;
    }

    #shopify-section-{{ section.id }} .tc__grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 12px;
    }

    #shopify-section-{{ section.id }} .tc__tab {
      padding: 8px 14px 10px;
      font-size: 12px;
    }
  }
</style>

<script>
  (function () {
    var sectionEl = document.getElementById('shopify-section-{{ section.id }}');
    if (!sectionEl) return;

    var tabs = sectionEl.querySelectorAll('.tc__tab');
    var panels = sectionEl.querySelectorAll('.tc__panel');

    tabs.forEach(function (tab) {
      tab.addEventListener('click', function () {
        var targetId = tab.getAttribute('data-tc-target');

        tabs.forEach(function (t) {
          t.classList.remove('tc__tab--active');
          t.setAttribute('aria-selected', 'false');
        });

        panels.forEach(function (p) {
          p.style.display = 'none';
          p.setAttribute('aria-hidden', 'true');
        });

        tab.classList.add('tc__tab--active');
        tab.setAttribute('aria-selected', 'true');

        var target = document.getElementById(targetId);
        if (target) {
          target.style.display = 'block';
          target.setAttribute('aria-hidden', 'false');
        }
      });
    });
  })();
</script>

{% schema %}
{
  "name": "Tabbed collections",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "Most Popular Products"
    },
    {
      "type": "range",
      "id": "products_count",
      "label": "Products per tab",
      "min": 4,
      "max": 12,
      "step": 4,
      "default": 8
    },
    {
      "type": "color",
      "id": "background",
      "label": "Background",
      "default": "#f4f4f4"
    }
  ],
  "blocks": [
    {
      "type": "collection",
      "name": "Tab",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Tab label",
          "default": "Products"
        },
        {
          "type": "collection",
          "id": "collection",
          "label": "Collection"
        },
        {
          "type": "select",
          "id": "filter",
          "label": "Filter",
          "info": "On Sale only shows products with a compare-at price set.",
          "options": [
            { "value": "none",    "label": "All products" },
            { "value": "on_sale", "label": "On Sale only" }
          ],
          "default": "none"
        }
      ]
    }
  ],
  "presets": [
    {
      "category": "Collections",
      "name": "Tabbed collections",
      "blocks": [
        { "type": "collection", "settings": { "title": "Bestsellers" } },
        { "type": "collection", "settings": { "title": "New Arrivals" } },
        { "type": "collection", "settings": { "title": "On Sale", "filter": "on_sale" } }
      ]
    }
  ]
}
{% endschema %}
