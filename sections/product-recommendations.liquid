{%- capture section_settings -%}
{
  "stackable": false,
  "layout": "vertical",
  "productId": {{ product.id | json }},
  "useRecommendations": true,
  "recommendationsCount": 10,
  "intent": {{ section.settings.intent | json | default: '"related"' }}
}
{%- endcapture -%}

<section class="section" data-section-id="{{ section.id }}" data-section-type="suggested-products" data-section-settings="{{ section_settings | escape_once }}">
  <div class="container">
    {%- if section.settings.heading != blank -%}
      <header class="section__header">
        <h2 class="section__title heading h3">{{ section.settings.heading | escape }}</h2>
      </header>
    {%- endif -%}

    <div class="product-recommendations">
      {%- comment -%}
        Always render a fallback product list so products are visible on initial load.
        When recommendations.performed is true (AJAX re-render), use Shopify recommendations.
        Otherwise fall back to collections.all so the section is never empty.
      {%- endcomment -%}

      {%- if recommendations.performed -%}
        {%- assign section_products = recommendations.products -%}
      {%- else -%}
        {%- assign section_products = nil -%}
      {%- endif -%}

      {%- if section_products == nil or section_products.size == 0 -%}
        {%- assign section_products = collections.all.products -%}
      {%- endif -%}

      <div class="scroller">
        <div class="scroller__inner">
          <div class="product-list product-list--vertical product-list--scrollable">
            {%- for rec_product in section_products limit: 10 -%}
              {%- unless rec_product.id == product.id -%}
                {%- render 'product-item', product: rec_product, grid_classes: '1/4--lap 1/5--desk 1/6--wide', show_add_to_cart: section.settings.show_quick_buy -%}
              {%- endunless -%}
            {%- endfor -%}
          </div>
        </div>
      </div>
    </div>
  </div>

  

  <div id="modal-quick-view-{{ section.id }}" class="modal" aria-hidden="true">
    <div class="modal__dialog modal__dialog--stretch" role="dialog">
      <button class="modal__close link" data-action="close-modal" title="{{ 'general.accessibility.close' | t | escape }}">
        {%- render 'icon', icon: 'close' -%}
      </button>

      <div class="modal__loader">
        {%- render 'icon', icon: 'search-loader' -%}
      </div>

      <div class="modal__inner"></div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Related products",
  "templates": ["product"],
  "settings": [
    {
      "type": "paragraph",
      "content": "Dynamic recommendations change and improve with time. Create manual product recommendations using the Shopify Search & Discovery app. [Learn more](https://help.shopify.com/en/manual/online-store/search-and-discovery/product-recommendations)."
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "You may also like"
    },
    {
      "type": "checkbox",
      "id": "show_quick_buy",
      "label": "Show quick buy",
      "default": false
    },
    {
      "type": "select",
      "id": "intent",
      "label": "Recommendation intent",
      "options": [
        {
          "value": "related",
          "label": "Related"
        },
        {
          "value": "complementary",
          "label": "Complementary"
        }
      ],
      "default": "related"
    }
  ],
  "presets": [
    {
      "category": "Products",
      "name": "Related products"
    }
  ]
}
{% endschema %}