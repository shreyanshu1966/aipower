          }
        },
        {
          "type": "testimonial",
          "settings": {
            "rating": 5,
            "quote": "The generator has handled everything I've thrown at it. Brilliant build quality and the price was competitive.",
            "name": "Mark R.",
            "trade": "Site Manager"
          }
        },
        {
          "type": "testimonial",
          "settings": {
            "rating": 5,
