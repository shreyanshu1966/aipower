<section class="testimonials-dark" data-section-id="{{ section.id }}" data-section-type="testimonials">

  {%- if section.settings.title != blank -%}
    <div class="container">
      <div class="testimonials-dark__header">
        <h2 class="testimonials-dark__title">{{ section.settings.title | escape }}</h2>
        {%- if section.settings.subtitle != blank -%}
          <p class="testimonials-dark__subtitle">{{ section.settings.subtitle | escape }}</p>
        {%- endif -%}
      </div>
    </div>
  {%- endif -%}

  <div class="testimonials-dark__scroll-outer">
    <div class="testimonials-dark__scroll" id="tscroll-{{ section.id }}">

      {%- for block in section.blocks -%}
        <div class="tc-card" {{ block.shopify_attributes }}>
          <span class="tc-card__qmark" aria-hidden="true">&ldquo;</span>

          <div class="tc-card__stars">
            {%- assign rating = block.settings.rating | default: 5 -%}
            {%- for i in (1..5) -%}
              <span class="tc-card__star {% unless i <= rating %}tc-card__star--off{% endunless %}">&#9733;</span>
            {%- endfor -%}
          </div>

          {%- if block.settings.quote != blank -%}
            <blockquote class="tc-card__quote">{{ block.settings.quote | escape }}</blockquote>
          {%- endif -%}

          <div class="tc-card__author">
            {%- if block.settings.name != blank -%}
              <span class="tc-card__name">{{ block.settings.name | escape }}</span>
            {%- endif -%}
            {%- if block.settings.trade != blank -%}
              <span class="tc-card__trade">{{ block.settings.trade | escape }}</span>
            {%- endif -%}
          </div>
        </div>

      {%- else -%}
        {%- for i in (1..3) -%}
          <div class="tc-card tc-card--placeholder">
            <span class="tc-card__qmark" aria-hidden="true">&ldquo;</span>
            <div class="tc-card__stars">
              {%- for j in (1..5) -%}<span class="tc-card__star">&#9733;</span>{%- endfor -%}
            </div>
            <blockquote class="tc-card__quote">Add your customer testimonials here to build trust with new visitors.</blockquote>
            <div class="tc-card__author">
              <span class="tc-card__name">Customer Name</span>
              <span class="tc-card__trade">Trade / Role</span>
            </div>
          </div>
        {%- endfor -%}
      {%- endfor -%}

    </div>
  </div>

</section>

<style>
  .testimonials-dark {
    background: #0d0d0d;
    padding: 100px 0;
    overflow: hidden;
  }

  .testimonials-dark__header {
    margin-bottom: 56px;
  }

  .testimonials-dark__title {
    font-size: 38px;
    font-weight: 900;
    letter-spacing: -0.03em;
    line-height: 1.05;
    color: #ffffff;
    margin: 0 0 14px;
    text-transform: uppercase;
  }

  .testimonials-dark__subtitle {
    font-size: 14px;
    color: rgba(255, 255, 255, 0.4);
    margin: 0;
    line-height: 1.6;
    max-width: 480px;
  }

  /* Scroll area */
  .testimonials-dark__scroll-outer {
    padding: 0 var(--container-gutter, 24px);
  }

  .testimonials-dark__scroll {
    display: flex;
    gap: 16px;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
    cursor: grab;
    padding-bottom: 4px;
  }

  .testimonials-dark__scroll::-webkit-scrollbar { display: none; }
  .testimonials-dark__scroll.is-dragging { cursor: grabbing; }

  /* Card */
  .tc-card {
    flex: 0 0 360px;
    scroll-snap-align: start;
    background: #161616;
    border: 1px solid rgba(255, 255, 255, 0.06);
    padding: 36px 32px 32px;
    display: flex;
    flex-direction: column;
    gap: 20px;
    position: relative;
    transition: border-color 0.3s ease;
  }

  .tc-card:hover { border-color: rgba(230, 0, 0, 0.35); }

  .tc-card--placeholder { opacity: 0.35; }

  .tc-card__qmark {
    position: absolute;
    top: 20px;
    right: 26px;
    font-size: 72px;
    line-height: 1;
    color: rgba(230, 0, 0, 0.15);
    font-family: Georgia, serif;
    pointer-events: none;
    user-select: none;
  }

  .tc-card__stars {
    display: flex;
    gap: 3px;
  }

  .tc-card__star {
    color: #e6a800;
    font-size: 14px;
    line-height: 1;
  }

  .tc-card__star--off { color: rgba(255, 255, 255, 0.15); }

  .tc-card__quote {
    font-size: 15px;
    line-height: 1.7;
    color: rgba(255, 255, 255, 0.75);
    margin: 0;
    font-style: normal;
    flex: 1;
  }

  .tc-card__author {
    display: flex;
    flex-direction: column;
    gap: 4px;
    padding-top: 20px;
    border-top: 1px solid rgba(255, 255, 255, 0.07);
  }

  .tc-card__name {
    font-size: 13px;
    font-weight: 700;
    color: #ffffff;
    letter-spacing: 0.01em;
  }

  .tc-card__trade {
    font-size: 10px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: #e60000;
  }

  @media screen and (max-width: 999px) {
    .testimonials-dark { padding: 72px 0; }
    .testimonials-dark__title { font-size: 30px; }
    .tc-card { flex: 0 0 300px; padding: 28px 24px 24px; }
  }

  @media screen and (max-width: 640px) {
    .testimonials-dark { padding: 56px 0; }
    .testimonials-dark__title { font-size: 24px; }
    .testimonials-dark__header { margin-bottom: 36px; }
    .tc-card { flex: 0 0 82vw; }
    .tc-card__qmark { font-size: 52px; }
  }
</style>

<script>
  (function() {
    document.addEventListener('DOMContentLoaded', function() {
      var el = document.getElementById('tscroll-{{ section.id }}');
      if (!el) return;
      var startX, scrollLeft, down = false;

      el.addEventListener('mousedown', function(e) {
        down = true;
        el.classList.add('is-dragging');
        startX = e.pageX - el.offsetLeft;
        scrollLeft = el.scrollLeft;
      });
      el.addEventListener('mouseleave', function() { down = false; el.classList.remove('is-dragging'); });
      el.addEventListener('mouseup',    function() { down = false; el.classList.remove('is-dragging'); });
      el.addEventListener('mousemove',  function(e) {
        if (!down) return;
        e.preventDefault();
        el.scrollLeft = scrollLeft - (e.pageX - el.offsetLeft - startX) * 1.4;
      });
    });
  })();
</script>

{% schema %}
{
  "name": "Testimonials",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "What Tradespeople Say"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subheading",
      "default": "Trusted by electricians, builders and site managers across the country."
