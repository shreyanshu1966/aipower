        },
        {
          "type": "text",
          "id": "trade",
          "label": "Trade / Role",
          "default": "Electrician"
        }
      ]
    }
  ],
  "max_blocks": 6,
  "presets": [
    {
      "name": "Testimonials",
      "category": "Social proof",
      "blocks": [
        {
          "type": "testimonial",
          "settings": {
            "rating": 5,
            "quote": "Absolutely brilliant quality. Ordered Monday, arrived Wednesday, and they've been solid on site ever since.",
            "name": "James T.",
