<section class="promo-marquee" data-section-id="{{ section.id }}" data-section-type="promo-banner">
  <div class="promo-marquee__wrap">
    <div class="promo-marquee__track" aria-label="{{ section.settings.title | escape }}">
      {%- for i in (1..10) -%}
        {%- if section.settings.label != blank -%}
          <span class="promo-marquee__tag">{{ section.settings.label | escape }}</span>
        {%- endif -%}
        <span class="promo-marquee__text">{{ section.settings.title | escape }}</span>
        <span class="promo-marquee__sep" aria-hidden="true">&#10022;</span>
      {%- endfor -%}
    </div>
    <div class="promo-marquee__track" aria-hidden="true">
      {%- for i in (1..10) -%}
        {%- if section.settings.label != blank -%}
          <span class="promo-marquee__tag">{{ section.settings.label | escape }}</span>
        {%- endif -%}
        <span class="promo-marquee__text">{{ section.settings.title | escape }}</span>
        <span class="promo-marquee__sep" aria-hidden="true">&#10022;</span>
      {%- endfor -%}
    </div>
  </div>

  {%- if section.settings.button_text != blank and section.settings.button_link != blank -%}
    <a href="{{ section.settings.button_link }}" class="promo-marquee__cta">
      {{ section.settings.button_text | escape }}
    </a>
  {%- endif -%}
</section>

<style>
  .promo-marquee {
    background: {{ section.settings.background }};
    color: {{ section.settings.text_color }};
    overflow: hidden;
    position: relative;
    display: flex;
    align-items: center;
  }

  .promo-marquee__wrap {
    display: flex;
    overflow: hidden;
    flex: 1;
    min-width: 0;
    mask-image: linear-gradient(to right, transparent 0%, black 6%, black 94%, transparent 100%);
    -webkit-mask-image: linear-gradient(to right, transparent 0%, black 6%, black 94%, transparent 100%);
  }

  .promo-marquee__track {
    display: inline-flex;
    align-items: center;
    white-space: nowrap;
    flex-shrink: 0;
    padding: 16px 0;
    animation: promo-marquee 35s linear infinite;
    will-change: transform;
  }

  .promo-marquee:hover .promo-marquee__track {
    animation-play-state: paused;
  }

  @keyframes promo-marquee {
    from { transform: translateX(0); }
    to   { transform: translateX(-50%); }
  }

  .promo-marquee__tag {
    font-size: 9px;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.16em;
    background: rgba(255, 255, 255, 0.18);
    padding: 3px 9px;
    margin-right: 14px;
    flex-shrink: 0;
  }

  .promo-marquee__text {
    font-size: 15px;
    font-weight: 700;
    letter-spacing: 0.02em;
    flex-shrink: 0;
  }

  .promo-marquee__sep {
    font-size: 8px;
    opacity: 0.5;
    margin: 0 28px;
    flex-shrink: 0;
  }

  .promo-marquee__cta {
    display: inline-block;
    margin: 12px 28px 12px 12px;
    padding: 9px 22px;
    border: 1px solid {{ section.settings.text_color }};
    color: {{ section.settings.text_color }};
    font-size: 11px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    text-decoration: none;
    white-space: nowrap;
    flex-shrink: 0;
    transition: background 0.2s ease, color 0.2s ease;
  }

  .promo-marquee__cta:hover {
    background: {{ section.settings.text_color }};
    color: {{ section.settings.background }};
  }

  @media (prefers-reduced-motion: reduce) {
    .promo-marquee__track { animation: none; }
  }
</style>

{% schema %}
{
  "name": "Promo Banner",
  "settings": [
    {
      "type": "text",
      "id": "label",
      "label": "Label",
      "default": "Limited Time"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Text",
      "default": "Free Delivery on Orders Over £75 — Shop Now"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button text",
      "default": "Shop the Deal"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "color",
      "id": "background",
      "label": "Background",
      "default": "#e60000"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#ffffff"
    }
  ],
  "presets": [
    {
      "name": "Promo Banner",
      "category": "Promotional"
    }
  ]
}
{% endschema %}
