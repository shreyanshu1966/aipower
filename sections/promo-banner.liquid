<section class="promo-banner" data-section-id="{{ section.id }}" data-section-type="promo-banner">
  <div class="container">
    <div class="promo-banner__inner">
      <div class="promo-banner__text">
        {%- if section.settings.label != blank -%}
          <span class="promo-banner__label">{{ section.settings.label | escape }}</span>
        {%- endif -%}
        {%- if section.settings.title != blank -%}
          <p class="promo-banner__title">{{ section.settings.title | escape }}</p>
        {%- endif -%}
      </div>

      {%- if section.settings.button_text != blank and section.settings.button_link != blank -%}
        <a href="{{ section.settings.button_link }}" class="promo-banner__cta">
          {{ section.settings.button_text | escape }}
        </a>
      {%- endif -%}
    </div>
  </div>
</section>

<style>
  #shopify-section-{{ section.id }} {
    background: {{ section.settings.background }};
    color: {{ section.settings.text_color }};
  }

  .promo-banner {
    padding: 20px 0;
  }

  .promo-banner__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 20px;
  }

  .promo-banner__text {
    display: flex;
    align-items: center;
    gap: 16px;
    flex-wrap: wrap;
  }

  .promo-banner__label {
    font-size: 10px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    background: rgba(255, 255, 255, 0.22);
    padding: 4px 10px;
    white-space: nowrap;
  }

  .promo-banner__title {
    font-size: 16px;
    font-weight: 700;
    margin: 0;
    line-height: 1.3;
  }

  .promo-banner__cta {
    display: inline-block;
    padding: 10px 26px;
    background: transparent;
    color: {{ section.settings.text_color }};
    border: 2px solid {{ section.settings.text_color }};
    font-size: 12px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    text-decoration: none;
    white-space: nowrap;
    flex-shrink: 0;
    transition: background 0.2s ease, color 0.2s ease;
  }

  .promo-banner__cta:hover {
    background: {{ section.settings.text_color }};
    color: {{ section.settings.background }};
  }

  @media screen and (max-width: 767px) {
    .promo-banner__inner {
      flex-direction: column;
      text-align: center;
      gap: 14px;
    }

    .promo-banner__text {
      flex-direction: column;
      gap: 6px;
    }

    .promo-banner__title {
      font-size: 14px;
    }
  }
</style>

{% schema %}
{
  "name": "Promo Banner",
  "settings": [
    {
      "type": "text",
      "id": "label",
      "label": "Label",
      "default": "Limited Time"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Text",
      "default": "Free Delivery on Orders Over £75 — Shop Now"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button text",
      "default": "Shop the Deal"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "color",
      "id": "background",
      "label": "Background",
      "default": "#e60000"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#ffffff"
    }
  ],
  "presets": [
    {
      "name": "Promo Banner",
      "category": "Promotional"
    }
  ]
}
{% endschema %}
