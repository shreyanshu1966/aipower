<style>
  .wishlist-page {
    padding: 40px 0 80px;
  }

  .wishlist-page__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 16px;
    margin-bottom: 40px;
  }

  .wishlist-page__title {
    margin: 0;
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .wishlist-page__badge {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: var(--accent-color, #ff4d4f);
    color: #fff;
    font-size: 0.75em;
    font-weight: 700;
    min-width: 28px;
    height: 28px;
    padding: 0 8px;
    border-radius: 14px;
    vertical-align: middle;
  }

  .wishlist-page__empty {
    text-align: center;
    padding: 100px 20px;
  }

  .wishlist-page__empty-icon {
    opacity: 0.15;
    margin-bottom: 24px;
  }

  .wishlist-page__empty p {
    opacity: 0.6;
    margin: 8px 0 0;
  }

  .wishlist-page__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 24px;
  }

  @media screen and (max-width: 1024px) {
    .wishlist-page__grid { grid-template-columns: repeat(3, 1fr); }
  }

  @media screen and (max-width: 699px) {
    .wishlist-page__grid { grid-template-columns: repeat(2, 1fr); gap: 12px; }
  }

  .wishlist-card {
    opacity: 1;
    transform: scale(1);
    transition: opacity 0.3s ease, transform 0.3s ease;
  }

  .wishlist-card--removing {
    opacity: 0;
    transform: scale(0.92);
    pointer-events: none;
  }

  .wishlist-remove-btn {
    position: absolute;
    top: 8px;
    left: 8px;
    z-index: 10;
    width: 32px;
    height: 32px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.95);
    border: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    visibility: hidden;
    transform: scale(0.8);
    transition: opacity 0.2s, visibility 0.2s, transform 0.2s;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.15);
    color: var(--text-color, #333);
  }

  .product-item:hover .wishlist-remove-btn {
    opacity: 1;
    visibility: visible;
    transform: scale(1);
  }

  .wishlist-remove-btn:hover {
    background: var(--accent-color, #ff4d4f);
    color: #fff;
  }

  .wishlist-card .product-item__quick-add-btn {
    display: block;
    width: 100%;
    margin-top: 10px;
    padding: 10px 16px;
    background: var(--primary-button-background);
    color: var(--primary-button-text-color);
    border: none;
    cursor: pointer;
    font-weight: 600;
    font-size: 0.85em;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    border-radius: var(--button-border-radius, 4px);
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    transition: opacity 0.2s;
  }

  .wishlist-card .product-item__quick-add-btn:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }

  .wishlist-card .product-item__quick-add-btn:hover:not(:disabled) {
    opacity: 0.85;
  }

  .wishlist-card .product-item__sold-out {
    display: block;
    width: 100%;
    margin-top: 10px;
    padding: 10px 16px;
    text-align: center;
    font-size: 0.85em;
    font-weight: 600;
    opacity: 0.4;
    border: 1px solid currentColor;
    border-radius: var(--button-border-radius, 4px);
  }
</style>

<div class="container wishlist-page">
  <div class="wishlist-page__header">
    <h1 class="wishlist-page__title heading h1">
      Wishlist
      <span class="wishlist-page__badge" id="wl-badge" style="display:none;">0</span>
    </h1>
    <button class="button button--secondary" id="wl-clear" style="display:none;" type="button">
      Clear all
    </button>
  </div>

  <div id="wl-empty" class="wishlist-page__empty" style="display:none;">
    <div class="wishlist-page__empty-icon">
      <svg xmlns="http://www.w3.org/2000/svg" width="80" height="80" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2">
        <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
      </svg>
    </div>
    <h2 class="heading h2">Your wishlist is empty</h2>
    <p>Save items you love by clicking the heart icon on any product.</p>
    <a href="{{ routes.collections_url }}" class="button button--primary" style="display:inline-flex; margin-top:24px;">
      Continue Shopping
    </a>
  </div>

  <div id="wl-grid" class="wishlist-page__grid"></div>
</div>

<script>
(function () {
  var WISHLIST_KEY = 'shopify_wishlist';
  var MONEY_FORMAT = {{ shop.money_format | json }};

  function getList() {
    return JSON.parse(localStorage.getItem(WISHLIST_KEY) || '[]');
  }

  function saveList(list) {
    localStorage.setItem(WISHLIST_KEY, JSON.stringify(list));
    document.querySelectorAll('.wishlist-count').forEach(function (el) {
      el.textContent = list.length;
      el.style.display = list.length > 0 ? 'inline-flex' : 'none';
    });
  }

  function formatMoney(cents) {
    var amount = (cents / 100).toFixed(2);
    return (MONEY_FORMAT || '{{amount}}')
      .replace('{{amount}}', amount)
      .replace('{{amount_no_decimals}}', Math.floor(cents / 100))
      .replace('{{amount_with_comma_separator}}', amount.replace('.', ','))
      .replace('{{amount_no_decimals_with_comma_separator}}', Math.floor(cents / 100));
  }

  var SVG_HEART = '<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="18" height="18" focusable="false" aria-hidden="true"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>';

  var SVG_CLOSE = '<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" width="13" height="13" focusable="false" aria-hidden="true"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>';

  var SVG_CART = '<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="16" height="16" focusable="false" aria-hidden="true"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/></svg>';

  function buildCard(product) {
    var img = product.featured_image
      ? product.featured_image.replace(/(\.\w+(\?.*)?$)/, '_400x400$1')
      : '';
    var imgTag = img
      ? '<img src="' + img + '" alt="' + escHtml(product.title) + '" loading="lazy" class="product-item__primary-image">'
      : '';
    var price = formatMoney(product.price);
    var comparePrice = product.compare_at_price_max > product.price
      ? '<s class="price price--compare">' + formatMoney(product.compare_at_price_max) + '</s> '
      : '';
    var vendorHtml = product.vendor
      ? '<a href="/collections/vendors?q=' + encodeURIComponent(product.vendor) + '" class="product-item__vendor">' + escHtml(product.vendor) + '</a>'
      : '';
    var variantId = product.variants[0].id;
    var actionHtml = product.available
      ? '<form class="wl-atc-form"><input type="hidden" name="quantity" value="1"><input type="hidden" name="id" value="' + variantId + '"><button type="submit" class="product-item__quick-add-btn">' + SVG_CART + ' Add to Cart</button></form>'
      : '<span class="product-item__sold-out">Sold out</span>';

    return '<div class="wishlist-card product-item product-item--vertical" data-wl-handle="' + product.handle + '">'
      + '<div class="product-item__media-container" style="position:relative;">'
        + '<a href="/products/' + product.handle + '" class="product-item__image-wrapper">'
          + '<div class="aspect-ratio aspect-ratio--square">' + imgTag + '</div>'
        + '</a>'
        + '<div class="product-item__floating-actions">'
          + '<button type="button" class="product-item__action-icon wishlist-icon is-active" data-product-handle="' + product.handle + '" aria-label="Remove from wishlist" style="background:var(--accent-color,#ff4d4f);color:#fff;">'
            + SVG_HEART
          + '</button>'
        + '</div>'
        + '<button type="button" class="wishlist-remove-btn" data-wl-remove="' + product.handle + '" aria-label="Remove" title="Remove from wishlist">'
          + SVG_CLOSE
        + '</button>'
      + '</div>'
      + '<div class="product-item__info">'
        + '<div class="product-item__info-inner">'
          + vendorHtml
          + '<a href="/products/' + product.handle + '" class="product-item__title">' + escHtml(product.title) + '</a>'
          + '<div class="product-item__price-list">' + comparePrice + '<span class="price">' + price + '</span></div>'
        + '</div>'
        + actionHtml
      + '</div>'
    + '</div>';
  }

  function escHtml(str) {
    return String(str).replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;');
  }

  function removeCard(handle) {
    var list = getList().filter(function (h) { return h !== handle; });
    saveList(list);
    var card = document.querySelector('[data-wl-handle="' + handle + '"]');
    if (card) {
      card.classList.add('wishlist-card--removing');
      setTimeout(function () {
        card.remove();
        syncUI();
      }, 320);
    }
  }

  function syncUI() {
    var grid = document.getElementById('wl-grid');
    var count = grid ? grid.querySelectorAll('.wishlist-card:not(.wishlist-card--removing)').length : 0;
    var badge = document.getElementById('wl-badge');
    var clearBtn = document.getElementById('wl-clear');
    var emptyEl = document.getElementById('wl-empty');

    if (badge) { badge.textContent = count; badge.style.display = count > 0 ? 'inline-flex' : 'none'; }
    if (clearBtn) clearBtn.style.display = count > 0 ? '' : 'none';
    if (emptyEl) emptyEl.style.display = count === 0 ? 'block' : 'none';
    if (grid) grid.style.display = count === 0 ? 'none' : 'grid';
  }

  function addToCart(form) {
    var btn = form.querySelector('button');
    if (btn) { btn.disabled = true; btn.style.opacity = '0.5'; }
    fetch(window.Shopify.routes.root + 'cart/add.js', { method: 'POST', body: new FormData(form) })
      .then(function (r) { return r.json(); })
      .then(function () {
        document.documentElement.dispatchEvent(new CustomEvent('product:added', { bubbles: true, detail: { quantity: 1 } }));
        document.documentElement.dispatchEvent(new CustomEvent('cart:refresh', { bubbles: true }));
      })
      .catch(console.error)
      .finally(function () {
        if (btn) { btn.disabled = false; btn.style.opacity = '1'; }
      });
  }

  document.addEventListener('DOMContentLoaded', function () {
    var grid = document.getElementById('wl-grid');
    var handles = getList();

    if (!grid) return;

    if (handles.length === 0) {
      syncUI();
      return;
    }

    Promise.all(
      handles.map(function (handle) {
        return fetch('/products/' + handle + '.js')
          .then(function (r) { return r.ok ? r.json() : null; })
          .catch(function () { return null; });
      })
    ).then(function (products) {
      products.filter(Boolean).forEach(function (product) {
        var el = document.createElement('div');
        el.innerHTML = buildCard(product);
        grid.appendChild(el.firstChild);
      });
      syncUI();
    });

    // Remove via X button
    grid.addEventListener('click', function (e) {
      var removeBtn = e.target.closest('[data-wl-remove]');
      if (removeBtn) {
        removeCard(removeBtn.dataset.wlRemove);
        return;
      }

      // Remove via heart icon click (global custom.js will also toggle localStorage)
      var heartBtn = e.target.closest('.wishlist-icon');
      if (heartBtn) {
        var handle = heartBtn.getAttribute('data-product-handle');
        if (handle) {
          setTimeout(function () {
            if (!getList().includes(handle)) removeCard(handle);
          }, 60);
        }
      }
    });

    // Add to cart
    grid.addEventListener('submit', function (e) {
      if (e.target.classList.contains('wl-atc-form')) {
        e.preventDefault();
        addToCart(e.target);
      }
    });

    // Clear all
    var clearBtn = document.getElementById('wl-clear');
    if (clearBtn) {
      clearBtn.addEventListener('click', function () {
        saveList([]);
        grid.innerHTML = '';
        syncUI();
      });
    }
  });
})();
</script>

{% schema %}
{
  "name": "Wishlist Page",
  "settings": []
}
{% endschema %}
