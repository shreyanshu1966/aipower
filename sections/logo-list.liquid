<section class="logo-ticker-section section" data-section-id="{{ section.id }}" data-section-type="brand-logos">

  {%- if section.settings.title != blank -%}
    <div class="container">
      <div class="logo-ticker-header">
        <span class="logo-ticker-label">{{ section.settings.title | escape }}</span>
        {%- if section.settings.link_title != blank and section.settings.link != blank -%}
          <a href="{{ section.settings.link }}" class="logo-ticker-link">{{ section.settings.link_title | escape }} &rarr;</a>
        {%- endif -%}
      </div>
    </div>
  {%- endif -%}

  <div class="logo-ticker">
    <div class="logo-ticker__track">

      {%- for block in section.blocks -%}
        <a {% if block.settings.link %}href="{{ block.settings.link }}"{% endif %} class="logo-ticker__item" {{ block.shopify_attributes }}>
          {%- if block.settings.image -%}
            {{- block.settings.image | image_url: width: 280 | image_tag: loading: 'lazy', widths: '140,280', class: 'logo-ticker__img' -}}
          {%- else -%}
            {{ 'image' | placeholder_svg_tag: 'logo-ticker__img logo-ticker__img--placeholder' }}
          {%- endif -%}
        </a>
      {%- endfor -%}

      {%- for block in section.blocks -%}
        <a {% if block.settings.link %}href="{{ block.settings.link }}"{% endif %} class="logo-ticker__item" aria-hidden="true" tabindex="-1">
          {%- if block.settings.image -%}
            {{- block.settings.image | image_url: width: 280 | image_tag: loading: 'lazy', widths: '140,280', class: 'logo-ticker__img' -}}
          {%- else -%}
            {{ 'image' | placeholder_svg_tag: 'logo-ticker__img logo-ticker__img--placeholder' }}
          {%- endif -%}
        </a>
      {%- endfor -%}

    </div>
  </div>

</section>

<style>
  .logo-ticker-section {
    padding: 60px 0;
    background: #fafafa;
    border-top: 1px solid rgba(0, 0, 0, 0.06);
    border-bottom: 1px solid rgba(0, 0, 0, 0.06);
  }

  .logo-ticker-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    margin-bottom: 36px;
  }

  .logo-ticker-label {
    font-size: 10px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    color: rgba(0, 0, 0, 0.38);
  }

  .logo-ticker-link {
    font-size: 11px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: #111;
    text-decoration: none;
    opacity: 0.45;
    transition: opacity 0.2s;
  }

  .logo-ticker-link:hover { opacity: 1; }

  /* Ticker */
  .logo-ticker {
    overflow: hidden;
    mask-image: linear-gradient(to right, transparent 0%, black 8%, black 92%, transparent 100%);
    -webkit-mask-image: linear-gradient(to right, transparent 0%, black 8%, black 92%, transparent 100%);
  }

  .logo-ticker__track {
    display: inline-flex;
    align-items: center;
    animation: logo-ticker 32s linear infinite;
    will-change: transform;
  }

  .logo-ticker-section:hover .logo-ticker__track {
    animation-play-state: paused;
  }

  @keyframes logo-ticker {
    from { transform: translateX(0); }
    to   { transform: translateX(-50%); }
  }

  .logo-ticker__item {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0 44px;
    flex-shrink: 0;
    text-decoration: none;
    opacity: 0.45;
    transition: opacity 0.25s ease;
    filter: grayscale(1);
  }

  .logo-ticker__item:hover {
    opacity: 0.85;
    filter: grayscale(0);
  }

  .logo-ticker__img {
    display: block;
    max-height: 52px;
    width: auto;
    max-width: 130px;
    object-fit: contain;
  }

  .logo-ticker__img--placeholder {
    width: 100px;
    height: 40px;
    opacity: 0.2;
  }

  @media (prefers-reduced-motion: reduce) {
    .logo-ticker__track { animation: none; }
  }

  @media screen and (max-width: 640px) {
    .logo-ticker-section { padding: 44px 0; }
    .logo-ticker__item { padding: 0 28px; }
    .logo-ticker__img { max-height: 36px; max-width: 90px; }
  }
</style>

{% schema %}
{
  "name": "Logo list",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "Authorized Distributors"
    },
    {
      "type": "text",
      "id": "link_title",
      "label": "Link title"
    },
    {
      "type": "url",
      "id": "link",
      "label": "Link"
    }
  ],
  "blocks": [
    {
      "type": "logo",
      "name": "Logo",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image",
          "info": "250 x 80px .jpg recommended"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "category": "Media",
      "name": "Logo list",
      "settings": {},
      "blocks": [
        { "type": "logo" },
        { "type": "logo" },
        { "type": "logo" },
        { "type": "logo" },
        { "type": "logo" },
        { "type": "logo" }
      ]
    }
  ]
}
{% endschema %}
