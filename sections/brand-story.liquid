<section class="brand-story section" data-section-id="{{ section.id }}" data-section-type="brand-story">
  <div class="container">
    <div class="brand-story__inner">

      <div class="brand-story__content">
        {%- if section.settings.label != blank -%}
          <span class="brand-story__label">{{ section.settings.label | escape }}</span>
        {%- endif -%}

        {%- if section.settings.title != blank -%}
          <h2 class="brand-story__title">{{ section.settings.title | escape }}</h2>
        {%- endif -%}

        {%- if section.blocks.size > 0 -%}
          <div class="brand-story__stats">
            {%- for block in section.blocks -%}
              <div class="brand-story__stat" {{ block.shopify_attributes }}>
                <span class="brand-story__stat-number">{{ block.settings.number | escape }}</span>
                <span class="brand-story__stat-label">{{ block.settings.label | escape }}</span>
              </div>
            {%- endfor -%}
          </div>
        {%- endif -%}

        {%- if section.settings.content != blank -%}
          <p class="brand-story__text">{{ section.settings.content | escape }}</p>
        {%- endif -%}

        {%- if section.settings.button_text != blank and section.settings.button_link != blank -%}
          <a href="{{ section.settings.button_link }}" class="brand-story__cta button button--primary">
            {{ section.settings.button_text | escape }}
          </a>
        {%- endif -%}
      </div>

      <div class="brand-story__image-container">
        {%- if section.settings.image != blank -%}
          {{- section.settings.image | image_url: width: 900 | image_tag: loading: 'lazy', class: 'brand-story__image', alt: section.settings.title -}}
        {%- else -%}
          {{ 'image' | placeholder_svg_tag: 'brand-story__image brand-story__image--placeholder placeholder-svg' }}
        {%- endif -%}
      </div>

    </div>
  </div>
</section>

<style>
  #shopify-section-{{ section.id }} {
    background: {{ section.settings.background }};
    color: {{ section.settings.text_color }};
  }

  .brand-story {
    padding: 80px 0;
  }

  .brand-story__inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 64px;
    align-items: center;
  }

  .brand-story__label {
    display: inline-block;
    font-size: 11px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: #e60000;
    margin-bottom: 18px;
  }

  .brand-story__title {
    font-size: 36px;
    font-weight: 800;
    line-height: 1.18;
    margin: 0 0 32px;
    color: inherit;
  }

  .brand-story__stats {
    display: flex;
    gap: 36px;
    margin-bottom: 32px;
    padding-bottom: 32px;
    border-bottom: 1px solid rgba(255, 255, 255, 0.12);
  }

  .brand-story__stat {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .brand-story__stat-number {
    font-size: 44px;
    font-weight: 900;
    line-height: 1;
    color: #e60000;
    letter-spacing: -0.02em;
  }

  .brand-story__stat-label {
    font-size: 11px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: rgba(255, 255, 255, 0.55);
  }

  .brand-story__text {
    font-size: 16px;
    line-height: 1.7;
    color: rgba(255, 255, 255, 0.72);
    margin: 0 0 30px;
    max-width: 500px;
  }

  .brand-story__image-container {
    border-radius: 3px;
    overflow: hidden;
    line-height: 0;
  }

  .brand-story__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .brand-story__image--placeholder {
    aspect-ratio: 4 / 3;
    opacity: 0.2;
  }

  @media screen and (max-width: 999px) {
    .brand-story__inner {
      grid-template-columns: 1fr;
      gap: 40px;
    }

    .brand-story__image-container {
      order: -1;
    }

    .brand-story__title {
      font-size: 28px;
    }

    .brand-story__stat-number {
      font-size: 34px;
    }
  }

  @media screen and (max-width: 640px) {
    .brand-story {
      padding: 52px 0;
    }

    .brand-story__stats {
      gap: 22px;
    }

    .brand-story__stat-number {
      font-size: 28px;
    }

    .brand-story__title {
      font-size: 24px;
      margin-bottom: 24px;
    }
  }
</style>

{% schema %}
{
  "name": "Brand Story",
  "settings": [
    {
      "type": "text",
      "id": "label",
      "label": "Label",
      "default": "Why AI Power"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "Built for Professionals Who Can't Afford Downtime"
    },
    {
      "type": "textarea",
      "id": "content",
      "label": "Content",
      "default": "We supply tradespeople, contractors and industrial teams with professional-grade tools and equipment. Every product is tested, genuine and backed by expert support — seven days a week."
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button text",
      "default": "Learn About Us"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image",
      "info": "800 x 600px .jpg recommended"
    },
    {
      "type": "color",
      "id": "background",
      "label": "Background",
      "default": "#111111"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#ffffff"
    }
  ],
  "blocks": [
    {
      "type": "stat",
      "name": "Stat",
      "settings": [
        {
          "type": "text",
          "id": "number",
          "label": "Number",
          "default": "500+"
        },
        {
          "type": "text",
          "id": "label",
          "label": "Label",
          "default": "Products"
        }
      ]
    }
  ],
  "max_blocks": 4,
  "presets": [
    {
      "name": "Brand Story",
      "category": "About",
      "blocks": [
        { "type": "stat", "settings": { "number": "500+", "label": "Professional Products" } },
        { "type": "stat", "settings": { "number": "10+", "label": "Years Experience" } },
        { "type": "stat", "settings": { "number": "50K+", "label": "Happy Customers" } }
      ]
    }
  ]
}
{% endschema %}
