<section class="brand-story section reveal" data-section-id="{{ section.id }}" data-section-type="brand-story">
  <div class="container">
    <div class="brand-story__inner">

      <div class="brand-story__content">
        {%- if section.settings.label != blank -%}
          <span class="brand-story__label">{{ section.settings.label | escape }}</span>
        {%- endif -%}

        {%- if section.settings.title != blank -%}
          <h2 class="brand-story__title">{{ section.settings.title | escape }}</h2>
        {%- endif -%}

        {%- if section.blocks.size > 0 -%}
          <div class="brand-story__stats">
            {%- for block in section.blocks -%}
              <div class="brand-story__stat" {{ block.shopify_attributes }}>
                <span class="brand-story__stat-number js-counter" data-target="{{ block.settings.number | escape }}">{{ block.settings.number | escape }}</span>
                <span class="brand-story__stat-label">{{ block.settings.label | escape }}</span>
              </div>
            {%- endfor -%}
          </div>
        {%- endif -%}

        {%- if section.settings.content != blank -%}
          <p class="brand-story__text">{{ section.settings.content | escape }}</p>
        {%- endif -%}

        {%- if section.settings.button_text != blank and section.settings.button_link != blank -%}
          <a href="{{ section.settings.button_link }}" class="brand-story__cta button button--primary">
            {{ section.settings.button_text | escape }}
          </a>
        {%- endif -%}
      </div>

      <div class="brand-story__image-container">
        {%- if section.settings.image != blank -%}
          {{- section.settings.image | image_url: width: 900 | image_tag: loading: 'lazy', class: 'brand-story__image', alt: section.settings.title -}}
        {%- else -%}
          {{ 'image' | placeholder_svg_tag: 'brand-story__image brand-story__image--placeholder placeholder-svg' }}
        {%- endif -%}
      </div>

    </div>
  </div>
</section>

<style>
  #shopify-section-{{ section.id }} {
    background: {{ section.settings.background }};
    color: {{ section.settings.text_color }};
  }

  .brand-story { padding: 110px 0; }

  .brand-story__inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 80px;
    align-items: center;
  }

  .brand-story__label {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    font-size: 10px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    color: #e60000;
    margin-bottom: 22px;
  }

  .brand-story__label::before {
    content: '';
    display: block;
    width: 28px;
    height: 1px;
    background: #e60000;
  }

  .brand-story__title {
    font-size: 40px;
    font-weight: 900;
    line-height: 1.1;
    letter-spacing: -0.03em;
    margin: 0 0 36px;
    color: inherit;
  }

  .brand-story__stats {
    display: flex;
    gap: 0;
    margin-bottom: 36px;
    padding-bottom: 36px;
    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
  }

  .brand-story__stat {
    display: flex;
    flex-direction: column;
    gap: 6px;
    padding-right: 32px;
    margin-right: 32px;
    border-right: 1px solid rgba(255, 255, 255, 0.08);
  }

  .brand-story__stat:last-child {
    border-right: none;
    margin-right: 0;
    padding-right: 0;
  }

  .brand-story__stat-number {
    font-size: 52px;
    font-weight: 900;
    line-height: 1;
    color: #e60000;
    letter-spacing: -0.04em;
  }

  .brand-story__stat-label {
    font-size: 10px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: rgba(255, 255, 255, 0.45);
  }

  .brand-story__text {
    font-size: 16px;
    line-height: 1.75;
    color: rgba(255, 255, 255, 0.65);
    margin: 0 0 32px;
    max-width: 480px;
  }

  .brand-story__image-container {
    overflow: hidden;
    line-height: 0;
    position: relative;
  }

  .brand-story__image-container::after {
    content: '';
    position: absolute;
    top: 16px;
    left: 16px;
    right: -16px;
    bottom: -16px;
    border: 1px solid rgba(230, 0, 0, 0.25);
    pointer-events: none;
    z-index: -1;
  }

  .brand-story__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .brand-story__image--placeholder {
    aspect-ratio: 4 / 3;
    opacity: 0.15;
  }

  /* CTA button overrides for dark bg */
  .brand-story__cta {
    display: inline-block;
    padding: 13px 28px;
    font-size: 12px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    text-decoration: none;
    border: 1px solid #e60000;
    color: #ffffff;
    background: #e60000;
    transition: background 0.2s ease, color 0.2s ease;
  }

  .brand-story__cta:hover {
    background: transparent;
    color: #e60000;
  }

  @media screen and (max-width: 999px) {
    .brand-story { padding: 72px 0; }
    .brand-story__inner { grid-template-columns: 1fr; gap: 44px; }
    .brand-story__image-container { order: -1; }
    .brand-story__image-container::after { display: none; }
    .brand-story__title { font-size: 30px; }
    .brand-story__stat-number { font-size: 38px; }
  }

  @media screen and (max-width: 640px) {
    .brand-story { padding: 56px 0; }
    .brand-story__stats { gap: 0; }
    .brand-story__stat { padding-right: 20px; margin-right: 20px; }
    .brand-story__stat-number { font-size: 30px; }
    .brand-story__title { font-size: 26px; margin-bottom: 24px; }
  }
</style>

<script>
  (function() {
    document.addEventListener('DOMContentLoaded', function() {
      var counters = document.querySelectorAll('#shopify-section-{{ section.id }} .js-counter');
      if (!counters.length || !('IntersectionObserver' in window)) return;

      var observer = new IntersectionObserver(function(entries) {
        entries.forEach(function(entry) {
          if (!entry.isIntersecting) return;
          observer.unobserve(entry.target);

          var el = entry.target;
          var raw = el.getAttribute('data-target') || '';
          var suffix = raw.replace(/[\d,\.]/g, '');
          var num = parseFloat(raw.replace(/[^\d.]/g, '')) || 0;
          var duration = 1600;
          var start = performance.now();

          function tick(now) {
            var t = Math.min((now - start) / duration, 1);
            var ease = 1 - Math.pow(1 - t, 4);
            var val = Math.round(ease * num);
            el.textContent = val + suffix;
            if (t < 1) requestAnimationFrame(tick);
          }
          requestAnimationFrame(tick);
        });
      }, { threshold: 0.4 });

      counters.forEach(function(el) { observer.observe(el); });
    });
  })();
</script>

{% schema %}
{
  "name": "Brand Story",
  "settings": [
    {
      "type": "text",
      "id": "label",
      "label": "Label",
      "default": "Why AI Power"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "Built for Professionals Who Can't Afford Downtime"
    },
    {
      "type": "textarea",
      "id": "content",
      "label": "Content",
      "default": "We supply tradespeople, contractors and industrial teams with professional-grade tools and equipment. Every product is tested, genuine and backed by expert support — seven days a week."
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button text",
      "default": "Learn About Us"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image",
      "info": "800 x 600px .jpg recommended"
    },
    {
      "type": "color",
      "id": "background",
      "label": "Background",
      "default": "#111111"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#ffffff"
    }
  ],
  "blocks": [
    {
      "type": "stat",
      "name": "Stat",
      "settings": [
        {
          "type": "text",
          "id": "number",
          "label": "Number",
          "default": "500+"
        },
        {
          "type": "text",
          "id": "label",
          "label": "Label",
          "default": "Products"
        }
      ]
    }
  ],
  "max_blocks": 4,
  "presets": [
    {
      "name": "Brand Story",
      "category": "About",
      "blocks": [
        { "type": "stat", "settings": { "number": "500+", "label": "Professional Products" } },
        { "type": "stat", "settings": { "number": "10+", "label": "Years Experience" } },
        { "type": "stat", "settings": { "number": "50K+", "label": "Happy Customers" } }
      ]
    }
  ]
}
{% endschema %}
