<section class="category-cards section reveal" data-section-id="{{ section.id }}" data-section-type="category-cards">
  {%- if section.settings.title != blank -%}
    <div class="container">
      <div class="category-cards__header">
        <h2 class="category-cards__title">{{ section.settings.title | escape }}</h2>
        {%- if section.settings.link_title != blank and section.settings.link != blank -%}
          <a href="{{ section.settings.link }}" class="category-cards__viewall">{{ section.settings.link_title | escape }} &rarr;</a>
        {%- endif -%}
      </div>
    </div>
  {%- endif -%}

  <div class="container">
    <div class="category-cards__grid">
      {%- for block in section.blocks -%}
        {%- assign coll = collections[block.settings.collection] -%}
        {%- assign placeholder_num = forloop.index0 | modulo: 6 | plus: 1 -%}
        {%- assign card_label = block.settings.label | default: coll.title -%}

        <a href="{{ coll.url | default: '/collections/all' }}" class="category-card" {{ block.shopify_attributes }}>
          <div class="category-card__media">
            {%- if coll.image -%}
              {{- coll.image | image_url: width: 800 | image_tag: loading: 'lazy', class: 'category-card__img', alt: card_label -}}
            {%- elsif block.settings.fallback_image != blank -%}
              {{- block.settings.fallback_image | image_url: width: 800 | image_tag: loading: 'lazy', class: 'category-card__img', alt: card_label -}}
            {%- else -%}
              {{- 'collection-' | append: placeholder_num | placeholder_svg_tag: 'category-card__img category-card__img--placeholder' -}}
            {%- endif -%}
          </div>

          <div class="category-card__overlay"></div>

          <div class="category-card__body">
            {%- if card_label != blank -%}
              <span class="category-card__name">
                <span class="category-card__name-accent"></span>
                {{ card_label | escape }}
              </span>
            {%- endif -%}
            {%- if coll.products_count > 0 -%}
              <span class="category-card__count">{{ coll.products_count }} Products</span>
            {%- endif -%}
            <span class="category-card__cta" aria-hidden="true">Shop Now &rarr;</span>
          </div>
        </a>
      {%- endfor -%}
    </div>
  </div>
</section>

<style>
  /* ── Category Cards: header ───────────────────────────── */
  .category-cards__header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 16px;
    padding-bottom: 28px;
    border-bottom: 1px solid rgba(0, 0, 0, 0.08);
    margin-bottom: 28px;
  }

  .category-cards__title {
    font-size: 32px;
    font-weight: 900;
    letter-spacing: -0.03em;
    line-height: 1;
    margin: 0;
    text-transform: uppercase;
  }

  .category-cards__viewall {
    font-size: 11px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: #111;
    text-decoration: none;
    white-space: nowrap;
    opacity: 0.55;
    transition: opacity 0.2s ease;
  }

  .category-cards__viewall:hover { opacity: 1; }

  /* ── Grid ─────────────────────────────────────────────── */
  .category-cards__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 10px;
  }

  /* ── Card ─────────────────────────────────────────────── */
  .category-card {
    position: relative;
    display: block;
    overflow: hidden;
    background: #111;
    text-decoration: none;
    aspect-ratio: 3 / 2;
  }

  @supports not (aspect-ratio: 3 / 2) {
    .category-card::before {
      content: '';
      display: block;
      padding-bottom: 66.67%;
    }
  }

  .category-card__media {
    position: absolute;
    top: 0; left: 0; right: 0; bottom: 0;
  }

  .category-card__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.65s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }

  .category-card__img--placeholder { opacity: 0.2; }

  .category-card:hover .category-card__img {
    transform: scale(1.06);
  }

  .category-card__overlay {
    position: absolute;
    top: 0; left: 0; right: 0; bottom: 0;
    background: linear-gradient(
      to top,
      rgba(0, 0, 0, 0.82) 0%,
      rgba(0, 0, 0, 0.18) 55%,
      rgba(0, 0, 0, 0) 100%
    );
    transition: background 0.4s ease;
  }

  .category-card:hover .category-card__overlay {
    background: linear-gradient(
      to top,
      rgba(180, 0, 0, 0.92) 0%,
      rgba(180, 0, 0, 0.5) 45%,
      rgba(0, 0, 0, 0.08) 100%
    );
  }

  .category-card__body {
    position: absolute;
    bottom: 0; left: 0; right: 0;
    padding: 24px 16px 18px;
    color: #fff;
  }

  /* Name with animated left accent bar */
  .category-card__name {
    display: flex;
    align-items: center;
    gap: 0;
    font-size: 15px;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    line-height: 1.15;
    overflow: hidden;
  }

  .category-card__name-accent {
    display: block;
    width: 0;
    height: 14px;
    background: #e60000;
    flex-shrink: 0;
    transition: width 0.3s cubic-bezier(0.22, 1, 0.36, 1);
    margin-right: 0;
    align-self: center;
  }

  .category-card:hover .category-card__name-accent {
    width: 3px;
    margin-right: 8px;
  }

  .category-card__count {
    display: block;
    font-size: 11px;
    margin-top: 5px;
    opacity: 0.6;
    font-weight: 500;
    letter-spacing: 0.02em;
    padding-left: 0;
    transition: padding-left 0.3s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .category-card:hover .category-card__count {
    padding-left: 11px;
  }

  .category-card__cta {
    display: block;
    font-size: 11px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    margin-top: 12px;
    padding-left: 11px;
    opacity: 0;
    transform: translateY(8px);
    transition: opacity 0.25s ease, transform 0.25s ease;
  }

  .category-card:hover .category-card__cta {
    opacity: 1;
    transform: translateY(0);
  }

  @media screen and (max-width: 999px) {
    .category-cards__grid {
      grid-template-columns: repeat(3, 1fr);
      gap: 8px;
    }
    .category-cards__title { font-size: 26px; }
  }

  @media screen and (max-width: 640px) {
    .category-cards__grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 6px;
    }
    .category-cards__header { margin-bottom: 18px; padding-bottom: 18px; }
    .category-cards__title { font-size: 22px; }
    .category-card__name { font-size: 13px; }
    .category-card__count { display: none; }
    .category-card__body { padding: 14px 12px 12px; }
  }
</style>

{% schema %}
{
  "name": "Category Cards",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "Shop by Category"
    },
    {
      "type": "text",
      "id": "link_title",
      "label": "View all label",
      "default": "View all categories"
    },
    {
      "type": "url",
      "id": "link",
      "label": "View all link"
    }
  ],
  "blocks": [
    {
      "type": "card",
      "name": "Category",
      "settings": [
        {
          "type": "collection",
          "id": "collection",
          "label": "Collection"
        },
        {
          "type": "text",
          "id": "label",
          "label": "Label override",
          "info": "Leave blank to use the collection title"
        },
        {
          "type": "image_picker",
          "id": "fallback_image",
          "label": "Fallback image",
          "info": "Shown if the collection has no image set"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Category Cards",
      "blocks": [
        { "type": "card" },
        { "type": "card" },
        { "type": "card" },
        { "type": "card" }
      ]
    }
  ]
}
{% endschema %}
