<style>
  .wishlist-page {
    padding: 40px 0 80px;
  }
  .wishlist-page__header {
    margin-bottom: 32px;
  }
  .wishlist-page__subtitle {
    margin-top: 6px;
    opacity: 0.6;
    font-size: 0.95em;
  }
  .wishlist-empty {
    text-align: center;
    padding: 80px 20px;
  }
  .wishlist-empty__icon {
    width: 64px;
    height: 64px;
    margin: 0 auto 20px;
    opacity: 0.2;
  }
  .wishlist-empty__title {
    margin-bottom: 10px;
  }
  .wishlist-empty__text {
    opacity: 0.6;
    margin-bottom: 24px;
  }
  .wishlist-loading {
    text-align: center;
    padding: 60px 20px;
    opacity: 0.5;
  }
  .wishlist-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 24px;
  }
  @media (min-width: 700px) {
    .wishlist-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }
  @media (min-width: 1100px) {
    .wishlist-grid {
      grid-template-columns: repeat(4, 1fr);
    }
  }
  .wl-card {
    transition: opacity 0.3s ease, transform 0.3s ease;
  }
  .wl-card.removing {
    opacity: 0;
    transform: scale(0.95);
  }
  .wl-card__media {
    position: relative;
    background: rgba(0,0,0,0.03);
    border-radius: 4px;
    overflow: hidden;
    margin-bottom: 12px;
  }
  .wl-card__media a {
    display: block;
    aspect-ratio: 1 / 1;
  }
  .wl-card__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .wl-card__remove {
    position: absolute;
    top: 8px;
    right: 8px;
    width: 34px;
    height: 34px;
    border-radius: 50%;
    border: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--accent-color, #ff4d4f);
    color: #fff;
    transition: opacity 0.2s;
  }
  .wl-card__remove:hover { opacity: 0.85; }
  .wl-card__remove svg {
    width: 14px;
    height: 14px;
    fill: currentColor;
    display: block;
  }
  .wl-card__title {
    font-size: 0.9em;
    font-weight: 500;
    margin-bottom: 6px;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .wl-card__title a {
    color: inherit;
    text-decoration: none;
  }
  .wl-card__title a:hover { text-decoration: underline; }
  .wl-card__price {
    font-size: 0.9em;
    margin-bottom: 10px;
  }
  .wl-card__price-compare {
    text-decoration: line-through;
    opacity: 0.5;
    margin-left: 6px;
    font-size: 0.85em;
  }
  .wl-card__atc {
    width: 100%;
    padding: 8px;
    font-size: 0.85em;
    cursor: pointer;
    border: 1px solid currentColor;
    background: transparent;
    border-radius: 2px;
    transition: background 0.2s, color 0.2s;
  }
  .wl-card__atc:hover {
    background: var(--primary-button-background, #000);
    color: var(--primary-button-text-color, #fff);
    border-color: transparent;
  }
  .wl-card__atc:disabled { opacity: 0.5; cursor: not-allowed; }
</style>

<div class="container wishlist-page">
  <div class="wishlist-page__header">
    <h1 class="heading h1">Wishlist</h1>
    <p class="wishlist-page__subtitle">
      <span id="wl-count">0</span> saved items
    </p>
  </div>

  <div id="wl-loading" class="wishlist-loading">Loading your wishlist…</div>

  <div id="wl-empty" class="wishlist-empty" style="display:none">
    <svg class="wishlist-empty__icon" viewBox="0 0 17 15" xmlns="http://www.w3.org/2000/svg">
      <path d="M15.0349331 1.40485867C14.1287273.49933787 12.9252477 0 11.6443673 0S9.16000731.49933787 8.25448651 1.40417371c-.01164437.01164436-.02328874.02328873-.03493311.03561806-.01164436-.01232933-.02260377-.02328873-.03424813-.0349331C7.2790995.49933787 6.07561989 0 4.79473949 0 3.51385908 0 2.31037947.49933787 1.40417371 1.40485867.49796794 2.31037947 0 3.51385908 0 4.79473949 0 6.07561989.4986529 7.2790995 1.40417371 8.1846203L8.2195534 15l6.8153797-6.8153797c.9055208-.9055208 1.4041737-2.10900041 1.4041737-3.38988081 0-1.28019545-.4986529-2.48436002-1.4041737-3.38988082z"/>
    </svg>
    <h2 class="wishlist-empty__title heading h3">Your wishlist is empty</h2>
    <p class="wishlist-empty__text">Save products you love by clicking the heart icon.</p>
    <a href="{{ routes.all_products_collection_url }}" class="button button--primary">Shop Now</a>
  </div>

  <div id="wl-grid" class="wishlist-grid" style="display:none"></div>
</div>

<script>
(function () {
  const WISHLIST_KEY = 'shopify_wishlist';
  const grid    = document.getElementById('wl-grid');
  const empty   = document.getElementById('wl-empty');
  const loading = document.getElementById('wl-loading');
  const countEl = document.getElementById('wl-count');

  const HEART_SVG = `<svg viewBox="0 0 17 15" xmlns="http://www.w3.org/2000/svg"><path d="M15.0349331 1.40485867C14.1287273.49933787 12.9252477 0 11.6443673 0S9.16000731.49933787 8.25448651 1.40417371c-.01164437.01164436-.02328874.02328873-.03493311.03561806-.01164436-.01232933-.02260377-.02328873-.03424813-.0349331C7.2790995.49933787 6.07561989 0 4.79473949 0 3.51385908 0 2.31037947.49933787 1.40417371 1.40485867.49796794 2.31037947 0 3.51385908 0 4.79473949 0 6.07561989.4986529 7.2790995 1.40417371 8.1846203L8.2195534 15l6.8153797-6.8153797c.9055208-.9055208 1.4041737-2.10900041 1.4041737-3.38988081 0-1.28019545-.4986529-2.48436002-1.4041737-3.38988082z"/></svg>`;

  function formatPrice(cents) {
    return (cents / 100).toFixed(3) + ' KWD';
  }

  function buildCard(product) {
    const variant  = product.variants[0];
    const imgSrc   = product.featured_image
      ? product.featured_image.replace(/(\.[^.]+)$/, '_400x400$1')
      : '';
    const hasCompare = variant.compare_at_price && variant.compare_at_price > variant.price;

    return `
      <div class="wl-card" data-handle="${product.handle}">
        <div class="wl-card__media">
          <a href="/products/${product.handle}">
            ${imgSrc
              ? `<img src="${imgSrc}" alt="${product.title}" loading="lazy">`
              : `<div style="aspect-ratio:1;background:rgba(0,0,0,0.05)"></div>`}
          </a>
          <button
            type="button"
            class="wl-card__remove wishlist-icon is-active"
            data-product-handle="${product.handle}"
            aria-label="Remove from wishlist"
            title="Remove from wishlist">
            ${HEART_SVG}
          </button>
        </div>
        <div class="wl-card__info">
          <p class="wl-card__title"><a href="/products/${product.handle}">${product.title}</a></p>
          <p class="wl-card__price">
            ${formatPrice(variant.price)}
            ${hasCompare ? `<span class="wl-card__price-compare">${formatPrice(variant.compare_at_price)}</span>` : ''}
          </p>
          ${variant.available
            ? `<form class="product-item__quick-add-form">
                 <input type="hidden" name="id" value="${variant.id}">
                 <input type="hidden" name="quantity" value="1">
                 <button type="submit" class="wl-card__atc">Add to Cart</button>
               </form>`
            : `<button class="wl-card__atc" disabled>Out of Stock</button>`}
        </div>
      </div>`;
  }

  function removeCard(handle) {
    const card = grid.querySelector(`[data-handle="${handle}"]`);
    if (!card) return;
    card.classList.add('removing');
    setTimeout(() => {
      card.remove();
      const remaining = grid.querySelectorAll('.wl-card').length;
      countEl.textContent = remaining;
      if (remaining === 0) {
        grid.style.display = 'none';
        empty.style.display = 'block';
      }
    }, 300);
  }

  function showEmpty() {
    loading.style.display = 'none';
    empty.style.display   = 'block';
    countEl.textContent   = 0;
  }

  async function init() {
    const handles = JSON.parse(localStorage.getItem(WISHLIST_KEY) || '[]');

    if (!handles.length) { showEmpty(); return; }

    countEl.textContent = handles.length;

    const results = await Promise.all(
      handles.map(h =>
        fetch(`/products/${h}.js`)
          .then(r => r.ok ? r.json() : null)
          .catch(() => null)
      )
    );

    const products = results.filter(Boolean);
    loading.style.display = 'none';

    if (!products.length) { showEmpty(); return; }

    countEl.textContent  = products.length;
    grid.innerHTML       = products.map(buildCard).join('');
    grid.style.display   = 'grid';

    // Remove card when heart is clicked (custom.js handles localStorage)
    grid.addEventListener('click', function (e) {
      const btn = e.target.closest('.wishlist-icon');
      if (!btn) return;
      removeCard(btn.getAttribute('data-product-handle'));
    });
  }

  init();
})();
</script>
