<section class="usp-ticker-section" data-section-id="{{ section.id }}" data-section-type="usp-bar" aria-label="Store benefits">
  <div class="usp-ticker">
    <div class="usp-ticker__track">

      {%- for block in section.blocks -%}
        <div class="usp-ticker__item" {{ block.shopify_attributes }}>
          <span class="usp-ticker__icon" aria-hidden="true">
            {%- case block.settings.icon -%}
              {%- when 'delivery' -%}
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="3" width="15" height="13"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
              {%- when 'shield' -%}
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><polyline points="9 12 11 14 15 10"/></svg>
              {%- when 'support' -%}
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 18v-6a9 9 0 0 1 18 0v6"/><path d="M21 19a2 2 0 0 1-2 2h-1a2 2 0 0 1-2-2v-3a2 2 0 0 1 2-2h3zM3 19a2 2 0 0 0 2 2h1a2 2 0 0 0 2-2v-3a2 2 0 0 0-2-2H3z"/></svg>
              {%- when 'returns' -%}
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="1 4 1 10 7 10"/><path d="M3.51 15a9 9 0 1 0 .49-3.51"/></svg>
              {%- when 'award' -%}
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="8" r="7"/><polyline points="8.21 13.89 7 23 12 20 17 23 15.79 13.88"/></svg>
              {%- else -%}
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
            {%- endcase -%}
          </span>
          <span class="usp-ticker__title">{{ block.settings.title | escape }}</span>
          {%- if block.settings.subtitle != blank -%}
            <span class="usp-ticker__subtitle">{{ block.settings.subtitle | escape }}</span>
          {%- endif -%}
          <span class="usp-ticker__sep" aria-hidden="true">&#9671;</span>
        </div>
      {%- endfor -%}

      {%- for block in section.blocks -%}
        <div class="usp-ticker__item" aria-hidden="true">
          <span class="usp-ticker__icon" aria-hidden="true">
            {%- case block.settings.icon -%}
              {%- when 'delivery' -%}
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="3" width="15" height="13"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
              {%- when 'shield' -%}
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><polyline points="9 12 11 14 15 10"/></svg>
              {%- when 'support' -%}
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 18v-6a9 9 0 0 1 18 0v6"/><path d="M21 19a2 2 0 0 1-2 2h-1a2 2 0 0 1-2-2v-3a2 2 0 0 1 2-2h3zM3 19a2 2 0 0 0 2 2h1a2 2 0 0 0 2-2v-3a2 2 0 0 0-2-2H3z"/></svg>
              {%- when 'returns' -%}
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="1 4 1 10 7 10"/><path d="M3.51 15a9 9 0 1 0 .49-3.51"/></svg>
              {%- when 'award' -%}
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="8" r="7"/><polyline points="8.21 13.89 7 23 12 20 17 23 15.79 13.88"/></svg>
              {%- else -%}
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
            {%- endcase -%}
          </span>
          <span class="usp-ticker__title">{{ block.settings.title | escape }}</span>
          {%- if block.settings.subtitle != blank -%}
            <span class="usp-ticker__subtitle">{{ block.settings.subtitle | escape }}</span>
          {%- endif -%}
          <span class="usp-ticker__sep" aria-hidden="true">&#9671;</span>
        </div>
      {%- endfor -%}

    </div>
  </div>
</section>

<style>
  .usp-ticker-section {
    background: #111111;
    border-top: 1px solid rgba(255, 255, 255, 0.06);
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
    overflow: hidden;
  }

  .usp-ticker {
    overflow: hidden;
    padding: 0;
  }

  .usp-ticker__track {
    display: inline-flex;
    align-items: center;
    white-space: nowrap;
    animation: usp-marquee 28s linear infinite;
    will-change: transform;
  }

  .usp-ticker-section:hover .usp-ticker__track {
    animation-play-state: paused;
  }

  @keyframes usp-marquee {
    from { transform: translateX(0); }
    to   { transform: translateX(-50%); }
  }

  .usp-ticker__item {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 17px 32px 17px 0;
    color: #ffffff;
    flex-shrink: 0;
  }

  .usp-ticker__icon {
    width: 18px;
    height: 18px;
    color: #e60000;
    flex-shrink: 0;
    display: flex;
    align-items: center;
  }

  .usp-ticker__icon svg {
    width: 100%;
    height: 100%;
    display: block;
  }

  .usp-ticker__title {
    font-size: 12px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    line-height: 1;
    white-space: nowrap;
  }

  .usp-ticker__subtitle {
    font-size: 11px;
    color: rgba(255, 255, 255, 0.45);
    font-weight: 500;
    letter-spacing: 0.02em;
    white-space: nowrap;
  }

  .usp-ticker__sep {
    font-size: 8px;
    color: #e60000;
    margin-left: 32px;
    opacity: 0.7;
    flex-shrink: 0;
  }

  @media (prefers-reduced-motion: reduce) {
    .usp-ticker__track { animation: none; }
  }
</style>

{% schema %}
{
  "name": "USP Bar",
  "max_blocks": 6,
  "settings": [],
  "blocks": [
    {
      "type": "usp_item",
      "name": "USP Item",
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "options": [
            { "value": "delivery", "label": "Delivery / Truck" },
            { "value": "shield",   "label": "Shield / Genuine" },
            { "value": "support",  "label": "Support / Headset" },
            { "value": "returns",  "label": "Returns / Refresh" },
            { "value": "award",    "label": "Award / Quality" }
          ],
          "default": "delivery"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Fast Delivery"
        },
        {
          "type": "text",
          "id": "subtitle",
          "label": "Subtitle",
          "default": "On all qualifying orders"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "USP Bar",
      "blocks": [
        { "type": "usp_item", "settings": { "icon": "delivery", "title": "Fast Delivery",    "subtitle": "On all qualifying orders" } },
        { "type": "usp_item", "settings": { "icon": "shield",   "title": "Genuine Products", "subtitle": "100% authentic brands"    } },
        { "type": "usp_item", "settings": { "icon": "support",  "title": "Expert Support",   "subtitle": "7 days a week"            } },
        { "type": "usp_item", "settings": { "icon": "returns",  "title": "Easy Returns",     "subtitle": "30-day hassle-free"       } }
      ]
    }
  ]
}
{% endschema %}
